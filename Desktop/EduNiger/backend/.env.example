# ============================================
# EduNiger — Configuration Backend
# ============================================

PORT=3000
NODE_ENV=development

# Base de données MySQL
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=root123
DB_NAME=gestion_scolaire
DB_PORT=3306

# JWT — générer avec: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=cb0ff70212aba2a5943d1cd513ef9491bd747b678058e56607fee3a4c11e2171c0f28b4a424c87bb35cedc0229fc9b8f
JWT_EXPIRE=7d

# CORS — origines autorisées (séparées par virgule)
ALLOWED_ORIGINS=http://localhost:5173

# ─────────────────────────────────────────────────────────────
# NOTIFICATIONS — Canal 1 : WhatsApp Cloud API (RECOMMANDÉ)
# Gratuit jusqu'à 1 000 messages/mois, ~0,01$ après
#
# Étapes d'activation :
#   1. Aller sur https://developers.facebook.com
#   2. Créer une app Business → ajouter le produit "WhatsApp"
#   3. Récupérer le "Phone Number ID" et le "Access Token"
#   4. Créer et soumettre vos 3 templates (voir GUIDE-WHATSAPP.md)
# ─────────────────────────────────────────────────────────────
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=

# Noms des templates approuvés par Meta (laisser les valeurs par défaut)
WHATSAPP_TEMPLATE_BULLETIN=eduniger_bulletin
WHATSAPP_TEMPLATE_NOTES=eduniger_notes
WHATSAPP_TEMPLATE_RETARD=eduniger_retard

# ─────────────────────────────────────────────────────────────
# NOTIFICATIONS — Canal 2 : Twilio SMS (fallback optionnel)
# Utilisé si WhatsApp échoue ou non configuré
# ─────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
